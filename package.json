{
  "name": "@handrail/quickbooks-node-sdk",
  "version": "0.1.5",
  "description": "Internal TypeScript SDK foundation for Handrail QuickBooks integration consumers.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "handrail-qbo": "./dist/bin/handrail-qbo.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist coverage",
    "lint": "eslint .",
    "test": "vitest run",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "handrail",
    "quickbooks",
    "sdk",
    "accounting"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.31",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.3"
  }
}
